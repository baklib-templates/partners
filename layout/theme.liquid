<!DOCTYPE html>
<html class="scroll-smooth partners-theme bg-slate-950" lang="{{ site.language }}">
  <head>
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="author" content="Baklib">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    {% meta_tags %}
    {{ 'stylesheets/application.css' | asset_url | stylesheet_tag: data-turbo-track: 'reload' }}
    {{ 'baklib/shared/main.css' | asset_url | stylesheet_tag: data-turbo-track: 'reload' }}
    {{ 'baklib/shared/main.js' | asset_url | stylesheet_tag: data-turbo-track: 'reload' }}
    {{ 'javascripts/application.js' | asset_url | script_tag: defer: true, data-turbo-track: 'reload' }}
    {%# TIPS：在低代码平台开发时，请打开下一行代码注释 %}
    {% if false %} {{ 'javascripts/cdn.tailwindcss.js' | asset_url | script_tag: data-turbo-track: 'reload' }} {% endif %}
    {% if page and page.template_name == 'page' %}
      {% render 'partner_json_ld', page: page %}
    {% endif %}
    {{ site.settings.head_html }}

    {% weixin_share_tag app_id: site.settings.weixin_app_id, app_secret: site.settings.weixin_app_secret, debug: site.settings.weixin_debug, enabled: site.settings.weixin_enabled %}
  </head>
  <body id="js--body" class="flex min-h-screen flex-col antialiased bg-slate-950 text-slate-200">
    <div class="flex-0">
      {% if site.settings.is_allow_header %}
        {% render 'header' %}
      {% endif %}
    </div>

    <main class="relative flex min-h-0 flex-1 flex-col bg-gradient-to-br from-slate-950 via-slate-900 to-slate-950">
      {{ content_for_layout }}
    </main>

    <div class="flex-0 border-t border-white/10 bg-slate-950/90 backdrop-blur-md">
      {% if site.settings.is_allow_footer %}
        {% render 'footer' %}
      {% endif %}
    </div>
  </body>
</html>
