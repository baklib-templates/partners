<header
  x-data=""
  x-ref="header"
  class="fixed z-50 w-full border-b border-white/10 bg-slate-950/70 px-2 py-2 text-slate-100 shadow-[0_1px_0_rgba(255,255,255,0.06)] backdrop-blur-md md:px-4">

  <div class="mx-auto flex w-full max-w-6xl justify-between">
    {% comment %} title & description {% endcomment %}
    <div class="flex flex-1 items-center justify-between space-x-2 px-0 pr-2 md:p-0">
      {% assign logo = 'images/logo.png' | asset_url %}
      <div class="avatar2">
        <div class="">
          <img src="{{ site.favicon_url | default: logo }}" class="h-10 justify-items-start rounded-full border border-white/20 bg-white/10" onerror="this.onerror=null;this.parentNode.parentNode.remove();"/>
        </div>
      </div>
      <div class='flex-1 min-w-0'>
        <h1>
          <a href="{{site.index_path}}" class="text-lg font-semibold tracking-tight text-white hover:underline sm:text-2xl">{{ site.name }}</a>
        </h1>
        <div class='line-clamp-1 text-xs text-slate-400'>{{ site.settings.slogan }}</div>
      </div>

      {% render 'header_drawer' %}
    </div>
    <div class="hidden items-center md:flex">
      <div class="flex grow flex-wrap items-center justify-start space-x-3 text-sm">
        {{ site.settings.header_menu_html }}
      </div>
      {% if current_user %}
        <div class='ml-4 flex items-center space-x-2'>
          <div class="dropdown dropdown-end">
            <div tabindex="0" role="button" class="avatar flex h-8 w-8 cursor-pointer items-center justify-center rounded-full bg-white/15 hue-rotate-15">
              {% if current_user.image %}
                <img src="{{ current_user.image }}" alt="{{ current_user.name }}" class="h-8 w-8 rounded-full object-cover" />
              {% else %}
                <svg class="h-8 w-8 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <circle cx="12" cy="8" r="4" />
                  <path d="M4 20c0-4 8-4 8-4s8 0 8 4" />
                </svg>
              {% endif %}
            </div>
            <div tabindex="0" class="dropdown-content mt-2 w-30 space-y-3 rounded-box bg-slate-900/95 px-3 py-2 text-slate-200 shadow-xl ring-1 ring-white/10 backdrop-blur-md">
              <div class="line-clamp-1 border-b border-white/10 pb-2 font-medium text-slate-100
              ">{{ current_user.name }}</div>
              <div class='text-slate-400'>
                {% form_tag 'sign_out' %}
                  <button class='h-[20px] w-full text-left hover:text-primary hover:underline'>{{ 'generic.buttons.signout' | t }}</button>
                {% endform_tag %}
              </div>
            </div>
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</header>
{% comment %} 补充 fixed header 内容高度 {% endcomment %}
<div class='h-[60px] md:h-[64px]' x-data="{headerHeight: 0}" x-init="$nextTick(() => { headerHeight = document.querySelector('header').offsetHeight; $el.style.height = headerHeight + 'px' })"></div>
