{% assign ptype_raw = page.settings.partner_type %}
{% assign ptype = ptype_raw.value | default: ptype_raw | default: 'agency' %}
{% assign display_title = page.settings.title | default: page.link_text %}
{% assign tagline = page.settings.tagline | strip %}
{% assign logo_u = page.settings.logo_image_url | presence %}
{% assign act = page.settings.action_link | strip %}
{% assign al = page.settings.action_label | strip %}
{% assign web_raw = page.settings.website_url %}
{% assign web = web_raw.value | default: web_raw | strip %}

<div class="relative z-10 mx-auto w-full max-w-6xl px-4 pb-16 pt-4 sm:px-6 lg:px-8">
  <div class="mb-4 hidden md:block">
    {% render 'breadcrumb', breadcrumb: page.breadcrumb %}
  </div>

  <section class="partners-glass-card overflow-hidden p-6 sm:p-10">
    <div class="flex flex-col items-start gap-8 lg:flex-row lg:items-center lg:justify-between">
      <div class="flex w-full flex-col gap-6 sm:flex-row sm:items-center">
        {% if logo_u %}
          <div class="flex h-24 w-24 shrink-0 items-center justify-center rounded-2xl bg-white p-3 shadow-inner ring-1 ring-black/5 dark:bg-slate-800 sm:h-28 sm:w-28">
            <img src="{{ logo_u }}" alt="{{ display_title | escape }}" class="max-h-full max-w-full object-contain" width="112" height="112" />
          </div>
        {% endif %}
        <div class="min-w-0 flex-1">
          <div class="flex flex-wrap gap-2">
            {% if ptype == 'integration' %}
              <span class="rounded-full bg-primary/15 px-2.5 py-0.5 text-xs font-semibold text-primary">{{ 'partners.type_integration' | t }}</span>
            {% else %}
              <span class="rounded-full bg-secondary/20 px-2.5 py-0.5 text-xs font-semibold text-sky-200">{{ 'partners.type_agency' | t }}</span>
            {% endif %}
            {% assign tier_raw = page.settings.partner_tier %}
            {% assign tier_v = tier_raw.value | default: tier_raw %}
            {% if tier_v == 'gold' %}
              <span class="rounded-full bg-amber-400/25 px-2.5 py-0.5 text-xs font-semibold text-amber-100">{{ 'partners.tier_gold' | t }}</span>
            {% elsif tier_v == 'silver' %}
              <span class="rounded-full bg-slate-400/25 px-2.5 py-0.5 text-xs font-semibold text-slate-200">{{ 'partners.tier_silver' | t }}</span>
            {% endif %}
          </div>
          <h1 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 dark:text-white sm:text-4xl">{{ display_title }}</h1>
          {% if tagline != blank %}
            <p class="mt-2 max-w-2xl text-base text-slate-600 dark:text-slate-300 sm:text-lg">{{ tagline }}</p>
          {% endif %}
        </div>
      </div>
      <div class="flex w-full shrink-0 flex-col gap-2 sm:flex-row lg:w-auto lg:flex-col">
        {% if act != blank %}
          <a href="{{ act }}" class="btn btn-primary btn-lg w-full sm:w-auto" {% if act contains 'http' %}target="_blank" rel="noopener noreferrer"{% endif %}>
            {% if al != blank %}{{ al }}{% elsif ptype == 'integration' %}{{ 'partners.install_app' | t }}{% else %}{{ 'partners.contact_partner' | t }}{% endif %}
          </a>
        {% endif %}
        {% if web != blank %}
          <a href="{{ web }}" class="btn btn-outline btn-lg w-full border-white/25 text-slate-800 dark:text-white sm:w-auto" target="_blank" rel="noopener noreferrer">{{ 'partners.visit_website' | t }}</a>
        {% endif %}
      </div>
    </div>
  </section>

  <div class="mt-8 flex flex-col gap-8 lg:flex-row lg:items-start">
    <article class="partners-glass-card min-h-[320px] min-w-0 flex-1 p-6 sm:p-8">
      <div id="page-content" class="partners-prose ProseMirror prose max-w-none">
        {{ page.settings.body }}
      </div>
      {% if site.settings.is_allow_feedback %}
        <div class="mt-10 border-t border-white/10 pt-8">
          {% render 'feedback_button', page: page %}
        </div>
      {% endif %}
    </article>

    <aside class="w-full shrink-0 space-y-4 lg:w-80 lg:sticky lg:top-28">
      <div class="partners-glass-card p-5">
        <h2 class="text-sm font-semibold uppercase tracking-wide text-slate-500">{{ 'partners.sidebar_resources' | t }}</h2>
        {% assign rl = page.settings.resource_links | strip %}
        {% if rl != blank %}
          <ul class="mt-3 space-y-2 text-sm">
            {% assign res_lines = rl | reg_split: '/\r?\n/' %}
            {% for line in res_lines %}
              {% assign line = line | strip %}
              {% if line != blank %}
                {% assign parts = line | reg_split: '/\|/' %}
                {% assign p0 = parts[0] | strip %}
                {% assign p1 = parts[1] | strip %}
                <li>
                  {% if p1 != blank %}
                    <a href="{{ p1 }}" class="link link-primary break-all" target="_blank" rel="noopener noreferrer">{{ p0 | default: p1 }}</a>
                  {% else %}
                    <a href="{{ p0 }}" class="link link-primary break-all" target="_blank" rel="noopener noreferrer">{{ p0 }}</a>
                  {% endif %}
                </li>
              {% endif %}
            {% endfor %}
          </ul>
        {% else %}
          <p class="mt-2 text-sm text-slate-500">—</p>
        {% endif %}
      </div>
      <div class="partners-glass-card p-5">
        <h2 class="text-sm font-semibold uppercase tracking-wide text-slate-500">{{ 'partners.sidebar_contact' | t }}</h2>
        {% assign em = page.settings.contact_email | strip %}
        {% if em != blank %}
          <a class="mt-2 block break-all text-sm text-primary hover:underline" href="mailto:{{ em }}">{{ em }}</a>
        {% else %}
          <p class="mt-2 text-sm text-slate-500">—</p>
        {% endif %}
      </div>
      <div class="partners-glass-card p-5">
        <h2 class="text-sm font-semibold uppercase tracking-wide text-slate-500">{{ 'partners.sidebar_industries' | t }}</h2>
        {% assign ind = page.settings.industries | strip %}
        {% if ind != blank %}
          <ul class="mt-3 flex flex-wrap gap-2">
            {% assign ind_parts = ind | reg_split: '/[,，\n]+/' %}
            {% for it in ind_parts %}
              {% assign it = it | strip %}
              {% if it != blank %}
                <li class="rounded-full bg-white/50 px-2.5 py-1 text-xs text-slate-800 ring-1 ring-black/5 dark:bg-slate-800/80 dark:text-slate-200 dark:ring-white/10">{{ it }}</li>
              {% endif %}
            {% endfor %}
          </ul>
        {% else %}
          <p class="mt-2 text-sm text-slate-500">—</p>
        {% endif %}
      </div>
    </aside>
  </div>
</div>

{% schema %}
  {
    "name": "t:schema.templates.page.name",
    "description": "t:schema.templates.page.description",
    "thumb_url": "images/theme/page.png",
    "sub_page_templates": ["page"],
    "settings": [
      {
        "id": "title",
        "type": "text",
        "label": "t:schema.templates.page.settings.title.label",
        "info": "t:schema.templates.page.settings.title.info"
      },
      {
        "id": "tagline",
        "type": "text",
        "label": "t:schema.templates.page.settings.tagline.label",
        "info": "t:schema.templates.page.settings.tagline.info"
      },
      {
        "id": "logo_image_url",
        "type": "image_picker",
        "label": "t:schema.templates.page.settings.logo_image_url.label",
        "info": "t:schema.templates.page.settings.logo_image_url.info"
      },
      {
        "id": "body",
        "type": "richtext",
        "label": "t:schema.templates.page.settings.body.label",
        "info": "t:schema.templates.page.settings.body.info"
      },
      {
        "id": "partner_type",
        "type": "select",
        "label": "t:schema.templates.page.settings.partner_type.label",
        "info": "t:schema.templates.page.settings.partner_type.info",
        "choices": [
          { "label": "技术 / 集成", "value": "integration" },
          { "label": "渠道 / 服务商", "value": "agency" }
        ],
        "default": "agency"
      },
      {
        "id": "region",
        "type": "select",
        "label": "t:schema.templates.page.settings.region.label",
        "info": "t:schema.templates.page.settings.region.info",
        "choices": [
          { "label": "北美", "value": "na" },
          { "label": "北欧", "value": "nordic" },
          { "label": "亚太", "value": "apac" }
        ],
        "default": "apac"
      },
      {
        "id": "partner_tier",
        "type": "select",
        "label": "t:schema.templates.page.settings.partner_tier.label",
        "info": "t:schema.templates.page.settings.partner_tier.info",
        "choices": [
          { "label": "金牌", "value": "gold" },
          { "label": "银牌", "value": "silver" }
        ],
        "default": "silver"
      },
      {
        "id": "website_url",
        "type": "text",
        "label": "t:schema.templates.page.settings.website_url.label"
      },
      {
        "id": "action_link",
        "type": "text",
        "label": "t:schema.templates.page.settings.action_link.label",
        "info": "t:schema.templates.page.settings.action_link.info"
      },
      {
        "id": "action_label",
        "type": "text",
        "label": "t:schema.templates.page.settings.action_label.label",
        "info": "t:schema.templates.page.settings.action_label.info"
      },
      {
        "id": "resource_links",
        "type": "textarea",
        "label": "t:schema.templates.page.settings.resource_links.label",
        "info": "t:schema.templates.page.settings.resource_links.info"
      },
      {
        "id": "contact_email",
        "type": "text",
        "label": "t:schema.templates.page.settings.contact_email.label"
      },
      {
        "id": "industries",
        "type": "textarea",
        "label": "t:schema.templates.page.settings.industries.label",
        "info": "t:schema.templates.page.settings.industries.info"
      }
    ]
  }
{% endschema %}
